{
  "name": "pos-system",
  "version": "1.0.0",
  "description": "POS System for small business",
  "main": "electron.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run copy-static",
    "copy-static": "xcopy .next\\static .next\\standalone\\.next\\static /E /I /Y",
    "start": "next start",
    "electron": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build:exe": "npm run build && electron-builder build --win --x64 --publish never"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.2.1",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.meridukaan.pos",
    "productName": "POS System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "bin/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "asarUnpack": [
      "bin/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}